{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/pre-commit-validate.sh",
        "matcher": "git\\s+commit",
        "failClosed": true
      },
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/pre-push-preflight.sh",
        "matcher": "git\\s+push"
      },
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/block-dangerous-ops.sh",
        "matcher": "git\\s+push\\s+.*--force|rm\\s+-rf\\s+/|kubectl\\s+.*apply.*prod",
        "failClosed": true
      }
    ],
    "beforeReadFile": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/redact-secrets.sh",
        "failClosed": false
      }
    ],
    "stop": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/session-complete.sh"
      }
    ]
  }
}
